<%- include("partials/head.ejs") %>
<%- include("partials/header.ejs") %>
<form method="POST" action="<%= job ? '/jobs/update/' + job.id : '/jobs' %>">
  <input type="hidden" name="_csrf" value="<%= _csrf %>" />
  <div>
    <label>Company:</label>
    <input name="company" value="<%= job ? job.company : '' %>" />
  </div>
  <div>
    <label>Position:</label>
    <input name="position" value="<%= job ? job.position : '' %>" />
  </div>
  <div>
    <label>Status:</label>
    <select name="status">
      <option value="pending" <%= job && job.status === 'pending' ? 'selected' : '' %>>pending</option>
      <option value="interview" <%= job && job.status === 'interview' ? 'selected' : '' %>>interview</option>
      <option value="declined" <%= job && job.status === 'declined' ? 'selected' : '' %>>declined</option>
    </select>
  </div>
  <div>
    <button><%= job ? 'update' : 'add' %></button>
    <a href="/jobs"><button type="button">Cancel</button></a>
  </div>
</form>
<%- include("partials/footer.ejs") %>
